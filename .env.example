# NWWS-OI credentials (request at https://www.weather.gov/nwws/nwws_oi_request)
NWWS_USER=your_username
NWWS_PASSWORD=your_password

# PostgreSQL
POSTGRES_USER=weatherwire
POSTGRES_PASSWORD=weatherwire
POSTGRES_DB=weatherwire
DATABASE_URL=postgresql+asyncpg://weatherwire:weatherwire@db:5432/weatherwire

# API
CORS_ORIGINS=http://localhost:3000
API_URL=http://localhost:8000

# Frontend (server-side fetch inside Docker)
API_URL=http://api:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Service mode: unset for API, set to "true" for ingest-only worker
INGEST_ONLY=false
